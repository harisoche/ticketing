.git
.gitignore
.idea
.vscode
.DS_Store

/bin/
/build/
/dist/
/storage/

# Local files
*.env.local
.env

# Test artifacts
*.test
*.out
coverage.*

# Documentation markdown isn't required at runtime, but keep
# docs/embed.go and docs/openapi.yaml — imported by the API.
docs/*.md
docs-out/

# Files in the repo root that don't need to ship
*.md
PHASE_*.md
phase-*.md
README.txt
*.postman_collection.json
api/
scripts/
