APP_ENV=development
APP_PORT=8080
DATABASE_URL=postgres://ticketing_user:ticketing_password@localhost:5432/ticketing_db?sslmode=disable

# A separate database used only by the optional repository integration
# verification (see README "Integration tests"). Not consumed by the API.
TEST_DATABASE_URL=postgres://ticketing_user:ticketing_password@localhost:5432/ticketing_db_test?sslmode=disable

JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_ISSUER=ticketing-api
JWT_ACCESS_TOKEN_TTL=24h

UPLOAD_STORAGE_DRIVER=local
UPLOAD_LOCAL_DIRECTORY=./storage/uploads
UPLOAD_MAX_SIZE_BYTES=5242880

# cmd/seed will hash this and use it for every demo user.
# Override to something else for non-default environments.
SEED_ADMIN_PASSWORD=password123
